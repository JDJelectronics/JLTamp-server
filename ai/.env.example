# Copy to .env and fill in. .env is gitignored — never commit real values.

# ── JLTamp server ────────────────────────────────────────────────────────────
JLTAMP_URL=http://192.168.1.10:8090

# Authenticate with EITHER a session token, OR email + password (the service
# exchanges those for a token at startup). The account owns the playlists the
# AI creates, so use the account whose library you want it to work with.
JLTAMP_TOKEN=
JLTAMP_EMAIL=
JLTAMP_PASSWORD=

# ── Embedding server (llama.cpp, started by scripts/start_embed_server.sh) ────
EMBED_URL=http://127.0.0.1:3100
EMBED_BATCH=64
EMBED_TIMEOUT=120

# ── This service ─────────────────────────────────────────────────────────────
AI_HOST=0.0.0.0
AI_PORT=5000

# Shared secret the app sends as X-AI-Key. Leave empty ONLY on a private
# tailnet — empty means anyone who can reach the port can drive the engine.
# Generate one with:  openssl rand -hex 24
AI_API_KEY=

# Browser origins allowed to call this service. Empty = no cross-origin access
# (native app only). Example: https://your-domain.example
AI_CORS_ORIGINS=

# Where vectors and the index live. Needs a few hundred MB.
AI_DATA_DIR=

# Optional: audio features from scripts/analyze_audio.py (BPM, energy) used to
# steer context prompts like "gym" or "slapen".
AI_FEATURES_FILE=

# ── Tuning ───────────────────────────────────────────────────────────────────
AI_MAX_TRACKS=50
AI_MIN_SCORE=0.30
AI_JOB_TIMEOUT_SEC=120
AI_LIBRARY_REFRESH_SEC=3600
