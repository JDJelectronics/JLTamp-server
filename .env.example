# ── JLTamp Music Server configuration ──
# Copy to `.env` and adjust. In Docker these are set via docker-compose.yml.

# Absolute path INSIDE the container to your music library (mounted read-only).
MUSIC_DIR=/music

# Where the server keeps its SQLite DB + extracted artwork cache.
DATA_DIR=/data

# Login for the app. Pick your own — this replaces your Plex account.
JLTAMP_USERNAME=admin
JLTAMP_PASSWORD=changeme

# A stable, unique server id (any random string). Identifies THIS server to the
# app. Leave blank to auto-generate + persist on first run.
SERVER_ID=

# Friendly name shown in the app.
SERVER_NAME=JLTamp

# Rescan the library automatically every N minutes (0 = only on startup + manual).
RESCAN_INTERVAL_MIN=0

# HTTP port the server listens on.
PORT=32400

# Local-first streaming. One OR more LAN / Tailscale addresses (comma-separated)
# the app can reach this server at directly, e.g. on the home network or over the
# tailnet. Advertised to the app at login; it prefers the fastest reachable one
# (Local > Tailscale > Remote) and falls back to the public URL when away —
# switching automatically on every network change without breaking playback.
# Only private (192.168/10/172.16-31), Tailscale (100.64/10 or *.ts.net) hosts
# are honoured; a public value here is ignored (the entered URL covers that).
# Blank = only the public/request address is offered.
#   LOCAL_URL=http://192.168.1.10:8090
#   LOCAL_URL=http://192.168.1.10:8090,https://host.tailXXXX.ts.net:8443
LOCAL_URL=
